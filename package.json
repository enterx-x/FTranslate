{
  "name": "pdf-translation-reader",
  "version": "0.1.0",
  "description": "Local offline PDF original text and Chinese translation reader for Windows desktop.",
  "main": "dist-electron/main/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && npm run build:electron && electron dist-electron/main/main.js\"",
    "test": "vitest run src",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run test && npm run typecheck && npm run build:renderer && npm run build:electron",
    "dist": "npm run build && set ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/&& electron-builder",
    "visual:check": "node scripts/visual-check.mjs"
  },
  "dependencies": {
    "@univerjs/preset-sheets-conditional-formatting": "^0.24.0",
    "@univerjs/preset-sheets-core": "^0.24.0",
    "@univerjs/preset-sheets-data-validation": "^0.24.0",
    "@univerjs/presets": "^0.24.0",
    "@xmldom/xmldom": "^0.8.13",
    "exceljs": "^4.4.0",
    "katex": "^0.17.0",
    "pdfjs-dist": "5.7.284",
    "pptxgenjs": "^4.0.1",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.14",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.local.pdf.translation.reader",
    "productName": "PDF Translation Reader",
    "directories": {
      "output": "dist"
    },
    "electronDist": "node_modules/electron/dist",
    "files": [
      "dist-renderer/**/*",
      "dist-electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PDF Translation Reader"
    }
  }
}
